#type vertex
#version 330 core
layout (location = 0) in vec3 aPos;

out vec3 TexCoords;

uniform mat4 u_ViewProjection;
uniform mat4 u_Transform;

void main()
{
    TexCoords = aPos;
    gl_Position = u_ViewProjection * u_Transform * vec4(aPos, 1.0);
} 

#type fragment
#version 330 core
out vec4 FragColor;

in vec3 TexCoords;

uniform samplerCube box;

void main()
{    
    FragColor = texture(box, TexCoords);
}